generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  passwordHash String
  role         String       @default("user") // "user" | "admin"
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  apiKeys      ApiKey[]
  requestLogs  RequestLog[]

  @@index([email])
}

model ApiKey {
  id            String       @id @default(cuid())
  userId        String
  name          String
  keyHash       String       @unique
  keyPrefix     String
  rateLimit     Int          @default(100)
  windowSeconds Int          @default(60)
  algorithm     String       @default("fixed") // "fixed" | "sliding"
  isActive      Boolean      @default(true)
  expiresAt     DateTime?
  deletedAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestLogs RequestLog[]
  abuseFlag   AbuseFlag?

  @@index([keyHash])
  @@index([userId])
}

model RequestLog {
  id             String   @id @default(cuid())
  apiKeyId       String
  userId         String
  ipAddress      String
  method         String
  path           String
  statusCode     Int
  responseTimeMs Int
  blocked        Boolean  @default(false)
  blockReason    String?
  userAgent      String?
  createdAt      DateTime @default(now())

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([apiKeyId])
  @@index([userId])
  @@index([createdAt])
  @@index([blocked])
}

model AbuseFlag {
  id        String   @id @default(cuid())
  apiKeyId  String   @unique
  reason    String
  flaggedAt DateTime @default(now())
  resolved  Boolean  @default(false)

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([resolved])
}
